{
  "name": "minecraft-stream-guard-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Full-screen live stream wall for StreamGuard — a Minecraft Paper/Spigot plugin.",
  "license": "GPL-3.0-only",
  "scripts": {
    "build": "tsc -b && vite build",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run check:architecture && npm run build",
    "check:architecture": "depcruise --config dependency-cruiser.cjs src",
    "dev": "vite",
    "format": "biome check . --write",
    "lint": "biome check .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/oswald": "^5.2.5",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dependency-cruiser": "^18.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
